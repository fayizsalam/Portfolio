        :root {
            --primary: #2563eb;
            --accent: #7c3aed;
        }

        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            overflow-x: hidden;
            background-color: #fff;
            color: #0f172a;
        }

        /* Modern Grain Effect */
        body::before {
            content: "";
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3%3Ffilter id='noiseFilter'%3E%3FfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3F/filter%3E%3Frect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3F/svg%3E");
            opacity: 0.03;
            pointer-events: none;
            z-index: 9999;
        }

        /* Custom Progress Bar */
        #progress-bar {
            height: 3px;
            background: linear-gradient(to right, var(--primary), var(--accent));
            width: 0%;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 1000;
        }

        /* Advanced Scroll Reveal */
        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s cubic-bezier(0.2, 1, 0.3, 1);
        }
        .reveal-left {
            opacity: 0;
            transform: translateX(-40px);
            transition: all 0.8s cubic-bezier(0.2, 1, 0.3, 1);
        }
        .reveal-right {
            opacity: 0;
            transform: translateX(40px);
            transition: all 0.8s cubic-bezier(0.2, 1, 0.3, 1);
        }
        .active {
            opacity: 1;
            transform: translate(0, 0);
        }

        /* Glass Card Effect */
        .glass-card {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.05);
        }

        /* Shine Hover Effect */
        .shine-hover {
            position: relative;
            overflow: hidden;
        }
        .shine-hover::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -100%;
            width: 100%;
            height: 200%;
            background: linear-gradient(to right, transparent, rgba(255, 255, 255, 0.4), transparent);
            transform: rotate(35deg);
            transition: 0.7s;
        }
        .shine-hover:hover::after {
            left: 100%;
        }

        /* Floating Animation */
        @keyframes float {
            0%, 100% { transform: translateY(0px) rotate(3deg); }
            50% { transform: translateY(-15px) rotate(5deg); }
        }
        .animate-float {
            animation: float 6s ease-in-out infinite;
        }

        /* Marquee */
        @keyframes marquee {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }
        .animate-marquee {
            display: flex;
            width: 200%;
            animation: marquee 30s linear infinite;
        }

        .skill-chip { 
            @apply px-5 py-2.5 bg-white border border-slate-100 text-slate-800 rounded-2xl text-[11px] font-bold uppercase tracking-widest transition-all duration-300 shine-hover flex items-center gap-2; 
        }
        .skill-chip:hover {
            @apply -translate-y-2 border-blue-200 shadow-xl shadow-blue-50 text-blue-600;
        }

        .section-heading { @apply text-[10px] font-black uppercase tracking-[0.5em] text-blue-600 mb-6 block; }

        .btn-magnetic { transition: transform 0.2s cubic-bezier(0.33, 1, 0.68, 1); }

        /* Bento Grid Specifics */
        .bento-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            grid-gap: 1.5rem;
        }

        #success-toast {
    position: fixed;
